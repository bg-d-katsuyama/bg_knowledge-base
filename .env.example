# ============================================================
# BG Knowledge Base - 環境変数テンプレート
# ============================================================
# このファイルをコピーして `.env` を作成してください:
#   cp .env.example .env
#
# 実値は絶対にコミットしないこと（.gitignoreで除外済み）。
# 本番環境では Secret Manager から取得します。
# ============================================================

# --- 実行環境 ---
# local | dev | prod
APP_ENV=local
LOG_LEVEL=INFO

# --- GCP ---
GCP_PROJECT_ID=
GCP_REGION=asia-northeast1
# ローカル開発でサービスアカウント鍵を使う場合のパス（本番は Workload Identity 推奨）
GOOGLE_APPLICATION_CREDENTIALS=

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=
# 既定モデル
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-5
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5

# --- Notion ---
NOTION_API_TOKEN=
NOTION_DB_KNOWLEDGE_ENTRY=
NOTION_DB_PEOPLE=
NOTION_DB_ORGANIZATION=
NOTION_DB_PROJECT=
NOTION_DB_TAG=

# --- Google Workspace (Drive / Meet) ---
# サービスアカウント経由で取得するため、認証情報は GCP に集約。
# ここでは「対象範囲」のみ宣言。
GDRIVE_TARGET_FOLDER_IDS=
GMEET_TRANSCRIPT_FOLDER_ID=

# --- Slack ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
# 同期対象チャンネルIDをカンマ区切りで指定
SLACK_TARGET_CHANNEL_IDS=
# 管理者ユーザーグループ
SLACK_ADMIN_USERGROUP=kb-admins

# --- 取り込み設定 ---
# 過去データ遡及範囲（ISO 8601、未設定なら全期間）
INGEST_SINCE=

# --- Claude API コスト制御 ---
CLAUDE_MAX_OUTPUT_TOKENS=2000
CLAUDE_BATCH_API_ENABLED=true
CLAUDE_PROMPT_CACHING_ENABLED=true
